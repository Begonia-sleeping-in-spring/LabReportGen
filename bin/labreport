#!/bin/bash

BASE_DIR="experiments"
STATE_FILE=".current_session"

if [ "$1" = "start" ]; then

    TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
    EXP_DIR="$BASE_DIR/exp_$TIMESTAMP"

    mkdir -p "$EXP_DIR"

    echo "START_TIME=$(date)" > "$EXP_DIR/metadata.conf"
    echo "STATUS=RUNNING" >> "$EXP_DIR/metadata.conf"

    echo "$EXP_DIR" > "$STATE_FILE"

    echo "Experiment started:"
    echo "$EXP_DIR"


elif [ "$1" = "snap" ]; then

    if [ ! -f "$STATE_FILE" ]; then
        echo "No active experiment. Run: labreport start"
        exit 1
    fi

    EXP_DIR=$(cat "$STATE_FILE")

    mkdir -p "$EXP_DIR"

    echo "[$(date)] $2" >> "$EXP_DIR/snapshots.log"

    echo "snap saved"


elif [ "$1" = "stop" ]; then

    if [ ! -f "$STATE_FILE" ]; then
        echo "No active experiment."
        exit 1
    fi

    EXP_DIR=$(cat "$STATE_FILE")

    echo "END_TIME=$(date)" >> "$EXP_DIR/metadata.conf"
    echo "STATUS=FINISHED" >> "$EXP_DIR/metadata.conf"

    echo "Experiment stopped:"
    echo "$EXP_DIR"


elif [ "$1" = "report" ]; then

    if [ ! -f "$STATE_FILE" ]; then
        echo "No active experiment."
        exit 1
    fi

    EXP_DIR=$(cat "$STATE_FILE")

    REPORT_DIR="reports"
    mkdir -p "$REPORT_DIR"

    REPORT_FILE="$REPORT_DIR/$(basename $EXP_DIR)_report.md"

    echo "# Lab Report" > "$REPORT_FILE"
    echo "" >> "$REPORT_FILE"
    echo "Experiment: $EXP_DIR" >> "$REPORT_FILE"
    echo "" >> "$REPORT_FILE"
    cat "$EXP_DIR/metadata.conf" >> "$REPORT_FILE"
    echo "" >> "$REPORT_FILE"

    echo "## Snapshots" >> "$REPORT_FILE"
    cat "$EXP_DIR/snapshots.log" >> "$REPORT_FILE"

    echo "Report generated:"
    echo "$REPORT_FILE"


else
    echo "Usage:"
    echo "  labreport start"
    echo "  labreport snap \"message\""
    echo "  labreport stop"
fi
