#!/bin/bash

BASE_DIR="experiments"
STATE_FILE=".current_session"

# =========================
# 命令记录（自动）
# =========================
labreport_log() {

    if [ -z "$LABREPORT_DIR" ]; then
        return
    fi

    CMD=$(history 1 | sed 's/^ *[0-9]* *//')

    echo "[$(date)] $CMD" >> "$LABREPORT_DIR/commands.log"

    #  自动检测编辑行为
    if echo "$CMD" | grep -q "nano"; then
        FILE=$(echo "$CMD" | awk '{print $2}')
        capture_file_content "$FILE"
    fi
}

# =========================
# start
# =========================
start() {
    TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
    EXP_DIR="$BASE_DIR/exp_$TIMESTAMP"

    mkdir -p "$EXP_DIR/screenshots"

    echo "$EXP_DIR" > "$STATE_FILE"

    export LABREPORT_DIR="$EXP_DIR"
    PROMPT_COMMAND="labreport_log"

    echo "START_TIME=$(date)" > "$EXP_DIR/metadata.conf"
    echo "STATUS=RUNNING" >> "$EXP_DIR/metadata.conf"

    echo "Experiment started:"
    echo "$EXP_DIR"
    

echo ""
echo "export LABREPORT_DIR=$(pwd)/$EXP_DIR"
echo "source $(pwd)/bin/labreport_hook.sh"
echo "export PROMPT_COMMAND=labreport_log"
echo ""

echo "请执行以上三条命令"
}

# =========================
# run（执行命令并记录输出）
# =========================
run_cmd() {
    if [ ! -f "$STATE_FILE" ]; then
        echo "No active experiment"
        exit 1
    fi

    EXP_DIR=$(cat "$STATE_FILE")
    CMD="$*"

    LOG="$EXP_DIR/events.log"

    echo "====================" >> "$LOG"
    echo "TIME: $(date)" >> "$LOG"
    echo "CMD: $CMD" >> "$LOG"

    OUTPUT=$($CMD 2>&1)

    echo "OUTPUT:" >> "$LOG"
    echo "$OUTPUT" >> "$LOG"

    echo "$OUTPUT"
}

# =========================
# snap（截图）
# =========================
snap() {
    if [ ! -f "$STATE_FILE" ]; then
        echo "No active experiment"
        exit 1
    fi

    EXP_DIR=$(cat "$STATE_FILE")
    IMG="$EXP_DIR/screenshots/$(date +%s).png"

    scrot "$IMG"

    echo "SNAP $(date) $1 -> $IMG" >> "$EXP_DIR/events.log"
    echo "snap saved: $IMG"
}

# =========================
# stop
# =========================
stop() {
    EXP_DIR=$(cat "$STATE_FILE")

    echo "END_TIME=$(date)" >> "$EXP_DIR/metadata.conf"
    echo "STATUS=FINISHED" >> "$EXP_DIR/metadata.conf"

    rm -f "$STATE_FILE"

    echo "Experiment stopped:"
    echo "$EXP_DIR"
}

# =========================
# generate（调用python）
# =========================
generate() {
    python3 tools/generate.py
}

# =========================
# 主入口（关键：你缺的就是这个）
# =========================
case "$1" in
    start)
        start
        ;;
    run)
        shift
        run_cmd "$@"
        ;;
    snap)
        snap "$2"
        ;;
    stop)
        stop
        ;;
    generate)
        generate
        ;;
    *)
        echo "Usage:"
        echo "  start"
        echo "  run <command>"
        echo "  snap <msg>"
        echo "  stop"
        echo "  generate"
        ;;
esac

